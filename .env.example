# Database (SQLite for local dev - swap to postgres:// for production)
DATABASE_URL="file:./dev.db"

# Auth.js / NextAuth
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
GITHUB_ID=""
GITHUB_SECRET=""

# Anthropic Claude API key (optional - enables AI-enhanced analysis)
ANTHROPIC_API_KEY="sk-ant-..."

# GitHub Personal Access Token (optional - raises rate limit for repository downloads)
GITHUB_TOKEN=""

# Base URL of the app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Internal-only admin token for temporary project trust settings
INTERNAL_ADMIN_TOKEN="change-me"
