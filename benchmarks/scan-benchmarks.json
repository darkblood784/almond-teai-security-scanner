        "requiredFindings": [
          {
            "type": "Exposed Git Repository",
            "category": "exposure",
            "severity": "high"
          }
        ],
        "scoreRange": { "min": 0, "max": 85 },
        "acceptableGrades": ["C", "D", "F"]
