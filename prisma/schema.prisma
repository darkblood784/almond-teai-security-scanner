generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id                String      @id @default(cuid())
  ownerId           String
  owner             User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  name              String
  projectType       String
  canonicalKey      String
  repoUrl           String?
  websiteUrl        String?
  sourceLabel       String?
  visibility        String      @default("private")
  publicSlug        String?     @unique
  verificationToken String      @default(cuid()) @unique
  monitoringEnabled Boolean     @default(false)
  badgeEligible     Boolean     @default(false)
  latestScanId      String?     @unique
  latestScan        Scan?       @relation("LatestProjectScan", fields: [latestScanId], references: [id], onDelete: SetNull)
  scans             Scan[]      @relation("ProjectScans")

  @@unique([ownerId, canonicalKey])
  @@index([projectType])
  @@index([visibility])
  @@index([ownerId, createdAt])
}

model Scan {
  id              String          @id @default(cuid())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  projectId       String
  project         Project         @relation("ProjectScans", fields: [projectId], references: [id], onDelete: Cascade)
  scanType        String          @default("github")
  repoUrl         String?
  repoName        String?
  fileName        String?
  websiteUrl      String?
  status          String          @default("pending")
  score           Int?
  summary         String?
  totalFiles      Int             @default(0)
  scannedFiles    Int             @default(0)
  linesScanned    Int             @default(0)
  errorMessage    String?
  aiSummary       String?
  previousScanId  String?
  previousScore   Int?
  scoreDelta      Int?
  regressionStatus String?
  regressionSummary String?
  newFindingsCount Int            @default(0)
  resolvedFindingsCount Int       @default(0)
  unchangedFindingsCount Int      @default(0)
  vulnerabilities Vulnerability[]
  latestForProject Project?       @relation("LatestProjectScan")

  @@index([projectId, createdAt])
  @@index([status])
}

model Vulnerability {
  id          String   @id @default(cuid())
  scanId      String
  scan        Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  type        String
  category    String   @default("code")
  severity    String
  confidence  String   @default("detected")
  exploitability String @default("none")
  file        String
  line        Int?
  code        String?
  description String
  suggestion  String
  createdAt   DateTime @default(now())

  @@index([scanId])
  @@index([severity])
  @@index([category])
}

model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String?   @unique
  emailVerified          DateTime?
  image                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  plan                   String    @default("free")
  monthlyScanLimit       Int       @default(3)
  monthlyScansUsed       Int       @default(0)
  monitoringProjectLimit Int       @default(0)
  isActive               Boolean   @default(true)
  projects               Project[]
  accounts               Account[]
  sessions               Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
